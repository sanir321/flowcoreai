# .env.example

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
LEGACY_SERVICE_ROLE_KEY=   # Legacy JWT format for edge functions (if using rotated sb_secret_* keys)

# OpenCode Zen (free AI models - LLM for agent responses)
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=

# GoWA (WhatsApp Bridge) Configuration
GOWA_BASE_URL=
GOWA_API_KEY=
GOWA_WEBHOOK_SECRET=   # Used by GoWA server to verify webhook signatures (set in Railway)

# Cron / Internal
INTERNAL_CRON_SECRET=   # MUST be different from GOWA_WEBHOOK_SECRET

# Google Workspace (Calendar/Sheets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=   # Required for OAuth login page

# SMTP / Email (for sending appointment confirmations, alerts, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Branding / SEO (REQUIRED: set to your production URL before deploy, e.g. https://flowter.vercel.app)
NEXT_PUBLIC_APP_URL=https://flowter.vercel.app
VERCEL_URL=   # Auto-set by Vercel (fallback if NEXT_PUBLIC_APP_URL is missing)

# Branding / Support
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_COMPANY_NAME=

# Google Search Console
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-site-verification-code

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=   # Legacy fallback for project token

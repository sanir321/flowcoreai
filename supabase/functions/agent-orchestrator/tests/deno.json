{
  "tasks": {
    "test": "deno test --allow-env --allow-net --allow-read --allow-write --no-check",
    "test-unit": "deno test --allow-env --allow-read --no-check --filter 'unit:'",
    "test-int": "deno test --allow-env --allow-net --allow-read --allow-write --no-check --filter 'int:'"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.unstable"]
  }
}

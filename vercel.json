{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/internal/gowa-health",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/internal/refresh-business-profiles",
      "schedule": "0 6 1 * *"
    }
  ]
}
